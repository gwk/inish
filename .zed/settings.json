// See: https://zed.dev/docs/configuring-zed#settings-files
{
  "file_scan_exclusions": ["**/.DS_Store"],
  "file_scan_inclusions": ["_plan.md", "_prompt.md", "_todo.md"],
  "tab_size": 2,
  "languages": {
    "CSS": {
      "format_on_save": "off",
    },
    "Just": {
      "format_on_save": "off",
    },
    "Python": {
      "formatter": {
        "external": {
          "command": "isort",
          "arguments": ["-", "--stdout"],
        },
      },
    },
    "TOML": {
      "format_on_save": "off",
    },
  },
}
